<Window x:Class="FluidBar.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluidBar 设置"
        Width="480" Height="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- === Mac 风格 Slider === -->
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="28">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush EndPoint="0,1">
                                                            <GradientStop Color="#0A84FF" Offset="0"/>
                                                            <GradientStop Color="#0077ED" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="#3A3A3C"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="20" Height="20"
                                                             Fill="White"
                                                             StrokeThickness="0">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="6"
                                                                              Opacity="0.3"
                                                                              ShadowDepth="1"
                                                                              Color="#000000"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="#0A84FF"
                                                             x:Name="InnerDot"
                                                             Opacity="0"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="InnerDot"
                                                                Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="InnerDot"
                                                                Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === ScrollBar 样式（极细 + 可见） === -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Margin" Value="0,2,2,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="2"
                                                        Background="#555555"
                                                        MinHeight="24"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === ToggleSwitch 样式 === -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid x:Name="SwitchRoot"
                              Width="44"
                              Height="22"
                              RenderTransformOrigin="0.5,0.5">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="SwitchScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.06" Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="SwitchScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.06" Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.94" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="SwitchScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.94" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#3A3A3C" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuarticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#34C759" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="22" Duration="0:0:0.24">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.25"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="SwitchScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Border x:Name="Track" CornerRadius="11"
                                    Width="44" Height="22">
                                <Border.Background>
                                    <SolidColorBrush x:Name="TrackBrush" Color="#3A3A3C"/>
                                </Border.Background>
                            </Border>
                            <Border x:Name="Thumb" CornerRadius="9"
                                    Background="#FFFFFF" Width="18" Height="18"
                                    HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" Opacity="0.3"
                                                      ShadowDepth="1"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === TabItem 样式 === -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Padding="16,10" Background="Transparent"
                                CornerRadius="8" Margin="0,0,2,0" Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2C2C2E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === ComboBox 样式（深色圆角风格） === -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3A3A3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"/>
                            <!-- 全区域可点击的透明 ToggleButton -->
                            <ToggleButton x:Name="Toggle"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent" BorderThickness="0"
                                          Cursor="Hand"/>
                            <!-- 选中内容（在 ToggleButton 外面，直接绑定 ComboBox 的 SelectedItem） -->
                            <ContentPresenter IsHitTestVisible="False"
                                              VerticalAlignment="Center"
                                              Margin="10,0,28,0"
                                              Content="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <!-- 下拉箭头 -->
                            <Path Data="M0,0 L4,4 L8,0"
                                  Stroke="#888888" StrokeThickness="1.5"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  IsHitTestVisible="False"
                                  Stretch="Uniform" Width="8" Height="5"/>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#2C2C2E" BorderBrush="#3A3A3C"
                                        BorderThickness="1" CornerRadius="8"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200"
                                        Margin="0,4,0,0">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0A84FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === ComboBoxItem 样式 === -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#260A84FF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- === 通用样式 === -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#D8D8DC"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#9A9AA0"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7B7B82"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="Separator" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Margin" Value="0,4,0,16"/>
        </Style>
        <!-- === 位置选择 RadioButton 样式 === -->
        <Style x:Key="PosRadioStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="Transparent"
                                CornerRadius="6" Cursor="Hand"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="PosScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PosScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.035" Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="PosScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.035" Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PosScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="PosScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.14"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="Bg" Property="Background"
                                        Value="#0DFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="#1A0A84FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主容器 -->
    <Border x:Name="MainBorder"
            CornerRadius="22"
            Background="#F30A0A0C"
            BorderBrush="#3AFFFFFF"
            BorderThickness="1"
            SizeChanged="MainBorder_SizeChanged">
        <Border.Effect>
            <DropShadowEffect BlurRadius="44" Opacity="0.62" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="3"
                    CornerRadius="22"
                    BorderThickness="1.2"
                    IsHitTestVisible="False"
                    Opacity="0.74">
                <Border.BorderBrush>
                    <LinearGradientBrush x:Name="SettingsRimBrush"
                                         StartPoint="0,0"
                                         EndPoint="1,1">
                        <LinearGradientBrush.RelativeTransform>
                            <RotateTransform x:Name="SettingsRimRotation"
                                             CenterX="0.5"
                                             CenterY="0.5"/>
                        </LinearGradientBrush.RelativeTransform>
                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                        <GradientStop Color="#06000000" Offset="0.24"/>
                        <GradientStop Color="#880A84FF" Offset="0.5"/>
                        <GradientStop Color="#0830D158" Offset="0.74"/>
                        <GradientStop Color="#24FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>

            <Border Grid.RowSpan="3"
                    Height="96"
                    CornerRadius="22,22,14,14"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Opacity="0.56">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#22FFFFFF" Offset="0"/>
                        <GradientStop Color="#070A84FF" Offset="0.55"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="20,16,20,0" Height="40">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="BackBtn"
                            Width="28" Height="28" CornerRadius="8"
                            Background="#0A84FF" Margin="0,0,10,0"
                            Cursor="Hand" Visibility="Collapsed"
                            MouseLeftButtonDown="BackBtn_Click">
                        <TextBlock Text="&#xE72B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="LogoIcon"
                            Width="44" Height="22" CornerRadius="11"
                            Background="#F4000000" Margin="0,0,12,0"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1">
                        <Grid>
                            <Border Height="8"
                                    VerticalAlignment="Top"
                                    CornerRadius="11,11,4,4"
                                    Opacity="0.28"
                                    IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Ellipse Width="5" Height="5"
                                     Fill="#0A84FF"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Margin="-8,0,0,0"/>
                            <Ellipse Width="5" Height="5"
                                     Fill="#30D158"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Margin="8,0,0,0"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="HeaderTitle"
                               Text="FluidBar"
                               FontSize="16" FontWeight="SemiBold"
                               FontFamily="Segoe UI, Microsoft YaHei UI"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="CloseBtn"
                        Content="&#xE8BB;"
                        Width="32" Height="32"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10"
                        Foreground="#888888"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background"
                                            Value="#33FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 内容区域 -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <TabControl x:Name="MainTabs"
                            Margin="16,4,16,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="1"
                            RenderTransformOrigin="0.5,0.5"
                            SelectedIndex="0">
                    <TabControl.RenderTransform>
                        <TranslateTransform x:Name="MainTabsTranslate" X="0"/>
                    </TabControl.RenderTransform>
                    <TabControl.Resources>
                        <Style TargetType="TabPanel">
                            <Setter Property="Background" Value="#10101012"/>
                            <Setter Property="Height" Value="40"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- ===== Tab 1: 灵动岛 ===== -->
                    <TabItem Header="灵动岛" FontSize="13"
                             FontFamily="Segoe UI, Microsoft YaHei UI"
                             Foreground="#CCCCCC">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      Padding="4,8,4,0">
                            <StackPanel>
                                <TextBlock Text="外观" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="圆角"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="CornerRadiusSlider" Grid.Column="1"
                                            Minimum="18" Maximum="34"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="CornerRadiusValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="透明度"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="OpacitySlider" Grid.Column="1"
                                            Minimum="0.3" Maximum="1.0"
                                            TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="OpacityValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="背景透明度"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="BackgroundOpacitySlider" Grid.Column="1"
                                            Minimum="0.1" Maximum="1.0"
                                            TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="BackgroundOpacityValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Border Style="{StaticResource Separator}"/>
                                <TextBlock Text="尺寸" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="灵动岛宽度"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="IslandWidthSlider" Grid.Column="1"
                                            Minimum="280" Maximum="640"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="IslandWidthValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="灵动岛高度"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="IslandHeightSlider" Grid.Column="1"
                                            Minimum="48" Maximum="96"
                                            TickFrequency="2"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="IslandHeightValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Border Style="{StaticResource Separator}"/>
                                <TextBlock Text="位置" Style="{StaticResource SectionHeader}"/>

                                <!-- 位置选择器 - 3x2 网格预览 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="屏幕位置"
                                               Style="{StaticResource SettingLabel}"
                                               VerticalAlignment="Top" Margin="0,10,0,0"/>
                                    <Grid Grid.Column="1" Margin="8,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 第一行: TopLeft, Top, TopRight -->
                                        <RadioButton x:Name="PosTopLeft" Tag="TopLeft"
                                                     Grid.Row="0" Grid.Column="0"
                                                     Margin="2"
                                                     Style="{StaticResource PosRadioStyle}"
                                                     Checked="PositionRadio_Changed">
                                            <StackPanel>
                                                <Border x:Name="PrevTL" Width="54" Height="28"
                                                        CornerRadius="8" Background="#2C2C2E"
                                                        BorderBrush="#1AFFFFFF" BorderThickness="1"/>
                                                <TextBlock Text="左上" FontSize="10"
                                                           Foreground="#888888"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton x:Name="PosTop" Tag="Top"
                                                     Grid.Row="0" Grid.Column="1"
                                                     Margin="2" IsChecked="True"
                                                     Style="{StaticResource PosRadioStyle}"
                                                     Checked="PositionRadio_Changed">
                                            <StackPanel>
                                                <Border x:Name="PrevT" Width="54" Height="28"
                                                        CornerRadius="8" Background="#2C2C2E"
                                                        BorderBrush="#1AFFFFFF" BorderThickness="1"/>
                                                <TextBlock Text="顶部" FontSize="10"
                                                           Foreground="#888888"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton x:Name="PosTopRight" Tag="TopRight"
                                                     Grid.Row="0" Grid.Column="2"
                                                     Margin="2"
                                                     Style="{StaticResource PosRadioStyle}"
                                                     Checked="PositionRadio_Changed">
                                            <StackPanel>
                                                <Border x:Name="PrevTR" Width="54" Height="28"
                                                        CornerRadius="8" Background="#2C2C2E"
                                                        BorderBrush="#1AFFFFFF" BorderThickness="1"/>
                                                <TextBlock Text="右上" FontSize="10"
                                                           Foreground="#888888"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- 第二行: BottomLeft, Bottom, BottomRight -->
                                        <RadioButton x:Name="PosBottomLeft" Tag="BottomLeft"
                                                     Grid.Row="1" Grid.Column="0"
                                                     Margin="2"
                                                     Style="{StaticResource PosRadioStyle}"
                                                     Checked="PositionRadio_Changed">
                                            <StackPanel>
                                                <Border x:Name="PrevBL" Width="54" Height="28"
                                                        CornerRadius="8" Background="#2C2C2E"
                                                        BorderBrush="#1AFFFFFF" BorderThickness="1"/>
                                                <TextBlock Text="左下" FontSize="10"
                                                           Foreground="#888888"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton x:Name="PosBottom" Tag="Bottom"
                                                     Grid.Row="1" Grid.Column="1"
                                                     Margin="2"
                                                     Style="{StaticResource PosRadioStyle}"
                                                     Checked="PositionRadio_Changed">
                                            <StackPanel>
                                                <Border x:Name="PrevB" Width="54" Height="28"
                                                        CornerRadius="8" Background="#2C2C2E"
                                                        BorderBrush="#1AFFFFFF" BorderThickness="1"/>
                                                <TextBlock Text="底部" FontSize="10"
                                                           Foreground="#888888"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton x:Name="PosBottomRight" Tag="BottomRight"
                                                     Grid.Row="1" Grid.Column="2"
                                                     Margin="2"
                                                     Style="{StaticResource PosRadioStyle}"
                                                     Checked="PositionRadio_Changed">
                                            <StackPanel>
                                                <Border x:Name="PrevBR" Width="54" Height="28"
                                                        CornerRadius="8" Background="#2C2C2E"
                                                        BorderBrush="#1AFFFFFF" BorderThickness="1"/>
                                                <TextBlock Text="右下" FontSize="10"
                                                           Foreground="#888888"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </RadioButton>
                                    </Grid>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="水平偏移"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="OffsetXSlider" Grid.Column="1"
                                            Minimum="-400" Maximum="400"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="OffsetXValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="垂直偏移"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="OffsetYSlider" Grid.Column="1"
                                            Minimum="-400" Maximum="400"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="OffsetYValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Border Style="{StaticResource Separator}"/>
                                <TextBlock Text="行为" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="显示时长"
                                               Style="{StaticResource SettingLabel}"/>
                                    <Slider x:Name="HideDelaySlider" Grid.Column="1"
                                            Minimum="1" Maximum="10"
                                            TickFrequency="0.5"
                                            IsSnapToTickEnabled="True"
                                            Margin="8,0"
                                            ValueChanged="Setting_ValueChanged"/>
                                    <TextBlock x:Name="HideDelayValue" Grid.Column="2"
                                               Style="{StaticResource ValueLabel}"/>
                                </Grid>

                                <Grid Margin="0,0,0,14" Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="始终显示"
                                               Style="{StaticResource SettingLabel}"/>
                                    <ToggleButton x:Name="AlwaysVisibleToggle"
                                                  Grid.Column="1" HorizontalAlignment="Left"
                                                  Margin="8,0" Width="44" Height="22"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Checked="AlwaysVisibleToggle_Changed"
                                                  Unchecked="AlwaysVisibleToggle_Changed"/>
                                </Grid>

                                <Grid Margin="0,0,0,14" Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="显示策略"
                                               Style="{StaticResource SettingLabel}"/>
                                    <ComboBox x:Name="DisplayStrategyCombo"
                                              Grid.Column="1" Margin="8,0"
                                              SelectionChanged="DisplayStrategyCombo_Changed">
                                        <ComboBoxItem Content="只显示最新" Tag="LatestOnly"/>
                                        <ComboBoxItem Content="同时显示多个" Tag="Multiple"/>
                                    </ComboBox>
                                </Grid>

                                <Border Style="{StaticResource Separator}"/>
                                <TextBlock Text="环绕微光" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,14" Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="流转模式"
                                               Style="{StaticResource SettingLabel}"/>
                                    <ComboBox x:Name="RimModeCombo"
                                              Grid.Column="1" Margin="8,0"
                                              SelectionChanged="RimModeCombo_Changed">
                                        <ComboBoxItem Content="始终流转" Tag="Always"/>
                                        <ComboBoxItem Content="新状态流转" Tag="Event"/>
                                        <ComboBoxItem Content="仅插件流转" Tag="Plugin"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Tab 2: 功能 ===== -->
                    <TabItem Header="功能" FontSize="13"
                             FontFamily="Segoe UI, Microsoft YaHei UI"
                             Foreground="#CCCCCC">
                        <Grid Margin="8,8">
                            <ListBox x:Name="MonitorList"
                                     Background="Transparent" BorderThickness="0"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="MonitorList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            CornerRadius="10" Padding="12"
                                                            Cursor="Hand"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="#00000000"/>
                                                        </Border.Background>
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="Background"
                                                                    Value="#1EFFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="#260A84FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="#2C2C2E"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Foreground="#0A84FF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"
                                                           FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="#888888"
                                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <ToggleButton Grid.Column="2"
                                                          Width="44" Height="22"
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          IsChecked="{Binding Enabled}"
                                                          Checked="MonitorToggle_Changed"
                                                          Unchecked="MonitorToggle_Changed"
                                                          Tag="{Binding Id}"
                                                          VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <!-- ===== Tab 3: 插件 ===== -->
                    <TabItem Header="插件" FontSize="13"
                             FontFamily="Segoe UI, Microsoft YaHei UI"
                             Foreground="#CCCCCC">
                        <Grid Margin="8,8">
                            <ListBox x:Name="PluginList"
                                     Background="Transparent" BorderThickness="0"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="PluginList_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            CornerRadius="10" Padding="12"
                                                            Cursor="Hand"
                                                            RenderTransformOrigin="0.5,0.5">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="#00000000"/>
                                                        </Border.Background>
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="Background"
                                                                    Value="#1EFFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="#260A84FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="36" Height="36"
                                                    CornerRadius="10"
                                                    Background="#2C2C2E"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Foreground="#0A84FF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#FFFFFF"
                                                           FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11"
                                                           Foreground="#888888"
                                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="&#xE76C;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       Foreground="#666666"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <!-- ===== Tab 4: 更多 ===== -->
                    <TabItem Header="更多" FontSize="13"
                             FontFamily="Segoe UI, Microsoft YaHei UI"
                             Foreground="#CCCCCC">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      Padding="4,8,4,0">
                            <StackPanel>
                                <TextBlock Text="常规" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,14" Height="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="开机自启动" FontSize="13"
                                                   Foreground="#CCCCCC"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <TextBlock Text="登录 Windows 时自动运行" FontSize="11"
                                                   Foreground="#666666"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="StartupToggle"
                                                  Grid.Column="1" Width="44" Height="22"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Checked="StartupToggle_Changed"
                                                  Unchecked="StartupToggle_Changed"/>
                                </Grid>

                                <Grid Margin="0,0,0,14" Height="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="隐藏托盘图标" FontSize="13"
                                                   Foreground="#CCCCCC"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <TextBlock Text="Ctrl+Alt+Click 灵动岛重新打开设置"
                                                   FontSize="11" Foreground="#666666"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="HideTrayToggle"
                                                  Grid.Column="1" Width="44" Height="22"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Checked="HideTrayToggle_Changed"
                                                  Unchecked="HideTrayToggle_Changed"/>
                                </Grid>

                                <Grid Margin="0,0,0,14" Height="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="按住隐藏" FontSize="13"
                                                   Foreground="#CCCCCC"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        <TextBlock Text="按住指定按键时临时隐藏灵动岛"
                                                   FontSize="11" Foreground="#666666"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ComboBox x:Name="HoldToHideKeyCombo"
                                              Grid.Column="1"
                                              Margin="12,0,0,0"
                                              SelectionChanged="HoldToHideKeyCombo_Changed"/>
                                </Grid>

                                <Border Style="{StaticResource Separator}"/>
                                <TextBlock Text="关于" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,14">
                                    <TextBlock Text="版本" FontSize="13"
                                               Foreground="#CCCCCC"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="2.0.0" FontSize="12"
                                               Foreground="#666666"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <Border Style="{StaticResource Separator}"/>

                                <Button x:Name="ResetBtn"
                                        Content="重置所有设置"
                                        Height="36" Padding="16,0"
                                        FontSize="12"
                                        FontFamily="Segoe UI, Microsoft YaHei UI"
                                        Foreground="#FF6B6B"
                                        Background="Transparent"
                                        BorderBrush="#33FF6B6B"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        HorizontalAlignment="Left"
                                        Click="ResetBtn_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg"
                                                    Background="Transparent"
                                                    BorderBrush="#33FF6B6B"
                                                    BorderThickness="1"
                                                    CornerRadius="8" Padding="16,0">
                                                <ContentPresenter
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg"
                                                            Property="Background"
                                                            Value="#1AFF6B6B"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bg"
                                                            Property="Background"
                                                            Value="#33FF6B6B"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- 插件详情页 -->
                <Grid x:Name="PluginDetailPanel" Visibility="Collapsed"
                      Margin="16,4,16,0"
                      Opacity="0"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="DetailPanelTranslate" X="28"/>
                    </Grid.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44"
                                        CornerRadius="12" Background="#2C2C2E">
                                    <TextBlock x:Name="DetailIcon"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="20" Foreground="#0A84FF"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <TextBlock x:Name="DetailName" FontSize="15"
                                               FontWeight="SemiBold" Foreground="#FFFFFF"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                    <TextBlock x:Name="DetailDesc" FontSize="12"
                                               Foreground="#888888"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16" Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="DetailEnabledLabel"
                                           Grid.Column="0" Text="启用项目" FontSize="13"
                                           Foreground="#CCCCCC"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           VerticalAlignment="Center"/>
                                <ToggleButton x:Name="DetailEnabledToggle"
                                              Grid.Column="1" Width="44" Height="22"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              Checked="DetailEnabled_Changed"
                                              Unchecked="DetailEnabled_Changed"/>
                            </Grid>

                            <Border Style="{StaticResource Separator}"/>
                            <TextBlock x:Name="DetailSettingsHeader"
                                       Text="项目设置"
                                       Style="{StaticResource SectionHeader}"/>
                            <StackPanel x:Name="PluginSettingsContainer"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- 底部拖拽区域 -->
            <Border Grid.Row="2" Height="24" Background="Transparent"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown"/>
        </Grid>
    </Border>
</Window>
